USE_FIXTURES=true

# Twitch developer application — used only for IGDB access tokens.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# eBay developer keys — Browse API for active marketplace listings.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# production | sandbox
EBAY_ENVIRONMENT=production

# Defaults to US marketplace listings when querying eBay.
EBAY_MARKETPLACE_ID=EBAY_US
