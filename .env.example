USE_FIXTURES=true

# Twitch developer application — used only for IGDB access tokens.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# eBay developer keys — Browse API for active marketplace listings.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# production | sandbox
EBAY_ENVIRONMENT=production

# Defaults to US marketplace listings when querying eBay.
EBAY_MARKETPLACE_ID=EBAY_US

# Optional supplemental catalogs (free API tiers — register keys at rawg.io / giantbomb.com).
RAWG_API_KEY=
GIANT_BOMB_API_KEY=

# Catalog breadth — raise merge caps after verifying upstream API quotas (defaults shown).
CATALOG_MERGE_MAX_RESULTS=40
IGDB_SEARCH_LIMIT=30
CATALOG_RAWG_LIMIT=15
CATALOG_GB_LIMIT=8

# HTMX suggestion dropdown uses smaller caps than full /search by default.
CATALOG_SUGGESTIONS_MERGE_MAX=24
CATALOG_SUGGESTIONS_IGDB_LIMIT=8
CATALOG_SUGGESTIONS_RAWG_LIMIT=6
CATALOG_SUGGESTIONS_GB_LIMIT=4

# SQLite feedback DB path (relative to cwd). Ensure directory exists or app creates it.
FEEDBACK_DB_PATH=data/feedback.db

# Secret token for GET /feedback/admin (Bearer header or ?token=). Leave unset to disable admin listing.
FEEDBACK_ADMIN_TOKEN=

# When true, unexpected errors may show exception type/message on the HTML error page (operators only).
DEBUG=false
